# Copia este archivo a .env y rellena los valores (nunca subas .env a git)

# Base de datos (Railway te da DATABASE_URL al crear PostgreSQL)
DATABASE_URL=postgresql://user:password@host:port/database

# Clave secreta para firmar los tokens de sesión (genera una aleatoria larga)
JWT_SECRET=tu-clave-secreta-muy-larga-y-aleatoria

# API de Google Gemini para generar resúmenes (https://aistudio.google.com/apikey)
GEMINI_API_KEY=tu-api-key-de-gemini

# Opcional
NODE_ENV=production
PORT=3000
